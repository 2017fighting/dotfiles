#!/bin/sh
# Phase: before_  (runs BEFORE file writes + .chezmoiexternals SSH clones).
# Trigger: run_once_ — installs the SSH-critical chain once per machine, then
# never again (it self-guards via `command -v bw`).
# Install the minimal chain `bw-ssh-add` needs to load SSH keys for the
# external clones later in the normal phase:
#   bitwarden-cli (bw)  <- `bw-ssh-add` shells out to `bw`
#   mise               <- runtime manager; needed by later scripts + tools
#
# Fast-exit: once bw + mise are on PATH this is a no-op on later applies. The
# full package set (Brewfile / Packages.pacman) is still restored by the
# after_ scripts (run_once_after_10/11); this script only guarantees the
# SSH-critical tools early.
set -eu

# Fast-exit: bw + mise already installed.
command -v bw >/dev/null 2>&1 && command -v mise >/dev/null 2>&1 && exit 0

{{ if eq .chezmoi.os "darwin" -}}
# macOS - Homebrew (brew is the one manual pre-req; it cannot bootstrap itself).
if ! command -v brew >/dev/null 2>&1; then
  echo "" >&2
  echo "===========================================================" >&2
  echo "[bootstrap] Homebrew NOT found - SSH bootstrap chain SKIPPED." >&2
  echo "[bootstrap] Without brew this script cannot install mise/bw," >&2
  echo "[bootstrap] so the SSH externals (oh-my-zsh, nvim, oh-my-tmux) will" >&2
  echo "[bootstrap] FAIL to clone later in this apply." >&2
  echo "[bootstrap] Fix: install Homebrew, then re-run 'chezmoi apply':" >&2
  echo "[bootstrap]   /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"" >&2
  echo "===========================================================" >&2
  echo "" >&2
  # Non-fatal (lifecycle scripts tolerate partial failure): let the non-SSH
  # parts of this apply still proceed. Re-running after installing brew is
  # idempotent - before_10 fast-exits once bw + mise are on PATH.
  exit 0
fi
brew install bitwarden-cli mise
{{ else if eq .chezmoi.os "linux" -}}
# Arch / WSL - pacman (pre-installed). sudo may prompt.
if command -v pacman >/dev/null 2>&1; then
  sudo pacman -S --needed --noconfirm bitwarden-cli mise >/dev/null 2>&1 \
    || echo "[bootstrap] pacman install (bitwarden-cli/mise) failed" >&2
else
  echo "[bootstrap] pacman not found - install bitwarden-cli + mise manually." >&2
fi
{{ else -}}
echo "[bootstrap] unsupported OS {{ .chezmoi.os }} - skipping" >&2
exit 0
{{ end -}}
