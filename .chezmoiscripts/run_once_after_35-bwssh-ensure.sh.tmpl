#!/bin/sh
# Ensure the bwssh (Bitwarden-backed) SSH agent daemon is running and the vault
# is unlocked BEFORE the SSH consumers run: run_70-ecc-install (clones ecc over
# SSH) and the .chezmoiexternals (oh-my-zsh, nvim, tmux, ecc — all cloned over
# SSH, the HTTPS ones forced to SSH by the global insteadOf in git/config.tmpl).
#
# POSITIONING — why run_once_after_35 (NOT run_31):
#   chezmoi executes .chezmoiscripts/ in strict ALPHABETICAL order of filename.
#   The numeric suffix is NOT a global priority queue — it only orders scripts
#   that share the same category prefix. `run_31-...` sorts BEFORE
#   `run_once_after_30-...` because, after the shared `run_`, the next char is
#   `3` (< `o`), so the old name ran this gate BEFORE mise installed bwssh →
#   `command -v bwssh` failed → gate skipped → ecc/externals cloned with no SSH
#   keys, forcing a second `chezmoi apply`. Joining the `run_once_after_` family
#   at 35 makes it sort AFTER run_30 (mise install of bwssh) and BEFORE
#   run_40 / run_70 + .config/* externals, which is the only ordering that matters.
#   A plain `run_` (every-apply) script CANNOT land in this gap cleanly: any
#   `run_<not once/onchange>` name diverges from `run_o...` at the `run_` boundary
#   and sorts before the whole family — so the gate must be run_once to share
#   the prefix.
#
# Why we materialize the config here:
#   chezmoi applies ~/.config/* FILES after all .chezmoiscripts/* (`.config`
#   sorts after `.chezmoiscripts` in target-path order), so
#   ~/.config/bwssh/config.toml is NOT on disk yet at position 35. The daemon
#   needs it (item_ids, bw_path) to load keys, so we render it from the source
#   template now via `chezmoi cat`. chezmoi writes the same file again in the
#   .config phase — idempotent, no harm.
#
# run_once (not every-apply): the gate only needs to guarantee readiness for the
# FIRST apply on a fresh machine. It re-runs when this script's rendered content
# changes — the config-version anchor below fires it when bwssh.agent.version
# bumps. Reboot/sleep persistence is handled by the launchd agent
# (run_onchange_after_81-bwssh-agent on macOS) and the systemd units
# (~/.config/systemd/user/bwssh-agent.{service,socket} on Linux). If the vault
# locks later and an external refresh needs SSH, run `bwssh unlock` manually.
# config-version={{ .bwssh.agent.version }}
set -eu

# Put mise's shims on PATH so the bwssh shim (installed by run_30's `mise i`) is
# resolvable. This is required on a fresh machine's FIRST apply: mise activates
# only via the oh-my-zsh `mise` plugin (no standalone `mise activate` line), and
# oh-my-zsh hasn't been cloned yet on apply #1, so the shims dir isn't on PATH.
# Without this, `command -v bwssh` fails → the gate skips → and being run_once it
# NEVER re-runs → SSH stays broken on every later apply too. mise always materializes
# shims here regardless of activation mode, so prepending the dir is sufficient.
_mise_shims="${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims"
if [ -d "$_mise_shims" ]; then
  case ":$PATH:" in
    *":$_mise_shims:"*) ;;          # already on PATH
    *) PATH="$_mise_shims:$PATH"; export PATH ;;
  esac
fi
unset _mise_shims

# bwssh not installed yet (e.g. run_30 mise install failed/skipped) → nothing to do.
command -v bwssh   >/dev/null 2>&1 || { echo "[bwssh-ensure] bwssh not on PATH (run_30 mise install?) — skipping" >&2; exit 0; }
command -v chezmoi >/dev/null 2>&1 || exit 0

# 1. Materialize the bwssh config (rendered from source; .config/* applies after scripts).
mkdir -p "$HOME/.config/bwssh"
if chezmoi cat "$HOME/.config/bwssh/config.toml" > "$HOME/.config/bwssh/config.toml.tmp" 2>/dev/null; then
  mv "$HOME/.config/bwssh/config.toml.tmp" "$HOME/.config/bwssh/config.toml"
else
  rm -f "$HOME/.config/bwssh/config.toml.tmp"
fi

# 2. Start the daemon if it isn't running (idempotent; portable — no plist/systemd dependency).
if ! bwssh status >/dev/null 2>&1; then
  echo "[bwssh-ensure] bwssh daemon down — starting" >&2
  bwssh start >/dev/null 2>&1 || true
fi

# 3. Wait for the agent socket to come up (bwssh-agentd is a Python daemon; ~5s budget).
i=0
while ! bwssh status >/dev/null 2>&1 && [ "$i" -lt 50 ]; do
  i=$((i + 1))
  sleep 0.1
done

# 4. Unlock the vault if locked (SSH consumers need keys in memory).
#    Exact-match the state value: 'unlocked' CONTAINS the substring 'locked',
#    so a naive `grep locked` would misfire on the unlocked state.
state=$(bwssh status 2>/dev/null | awk '/^State:/ {print $2; exit}')
case "${state:-unknown}" in
  locked)
    if [ -t 0 ]; then
      echo "[bwssh-ensure] vault locked — unlocking (enter Bitwarden master password)" >&2
      bwssh unlock || echo "[bwssh-ensure] unlock failed — SSH steps may fail" >&2
    else
      echo "[bwssh-ensure] WARNING: vault locked, no TTY — run 'bwssh unlock' (and 'bw login' first on a fresh machine)" >&2
    fi
    ;;
  unlocked)
    # nothing to do
    ;;
  *)
    echo "[bwssh-ensure] unknown bwssh state '${state:-<empty>}' — leaving as-is" >&2
    ;;
esac
