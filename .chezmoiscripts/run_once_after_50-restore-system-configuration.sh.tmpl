#!/bin/sh
{{ if .is_darwin }}

# ---------------------------------------------------------------------------------------------------------------------
# Global settings
# ---------------------------------------------------------------------------------------------------------------------
# 修改键盘重复按键的延迟和速度
defaults write NSGlobalDomain InitialKeyRepeat -int 15
defaults write NSGlobalDomain KeyRepeat -int 2
# 设置键盘UI模式为暗黑模式
defaults write NSGlobalDomain AppleKeyboardUIMode -int 3
# 显示所有扩展
defaults write NSGlobalDomain AppleShowAllExtensions -bool true
# 禁用窗口动画
defaults write NSGlobalDomain NSAutomaticWindowAnimationsEnabled -bool false
# 保存模式下的导航面板展开状态
defaults write NSGlobalDomain NSNavPanelExpandedStateForSaveMode -bool true
defaults write NSGlobalDomain NSNavPanelExpandedStateForSaveMode2 -bool true
# 启用 FN 键状态
defaults write NSGlobalDomain "com.apple.keyboard.fnState" -bool true
# 隐藏菜单栏
defaults write NSGlobalDomain _HIHideMenuBar -bool true
# 设置鼠标点击行为
defaults write NSGlobalDomain "com.apple.mouse.tapBehavior" -int 1
# 设置系统声音的音量和反馈
defaults write NSGlobalDomain "com.apple.sound.beep.volume" -float 0.0
defaults write NSGlobalDomain "com.apple.sound.beep.feedback" -int 0
# 禁用按住键
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

# ---------------------------------------------------------------------------------------------------------------------
# finder
# ---------------------------------------------------------------------------------------------------------------------
# 隐藏外部硬盘图标
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool false
# 隐藏硬盘图标
defaults write com.apple.finder ShowHardDrivesOnDesktop -bool false
# 隐藏挂载的服务器
defaults write com.apple.finder ShowMountedServersOnDesktop -bool false
# 显示可移动媒体
defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool true
# 文件夹优先排序
defaults write com.apple.finder _FXSortFoldersFirst -bool true
# 搜索默认当前文件夹
defaults write com.apple.finder FXDefaultSearchScope -string "SCcf"

# ---------------------------------------------------------------------------------------------------------------------
# Desktop Services 设置
# ---------------------------------------------------------------------------------------------------------------------
# 禁止在网络和 USB 设备上创建 .DS_Store 文件
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true

# ---------------------------------------------------------------------------------------------------------------------
# Spaces 设置
# ---------------------------------------------------------------------------------------------------------------------
# 显示为每个显示器分别管理 Spaces
defaults write com.apple.spaces "spans-displays" -int 0

# ---------------------------------------------------------------------------------------------------------------------
# Window Manager 设置
# ---------------------------------------------------------------------------------------------------------------------
# 点击桌面显示所有窗口
defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -int 0
# 显示桌面图标
defaults write com.apple.WindowManager StandardHideDesktopIcons -int 0
# 不隐藏桌面项目
defaults write com.apple.WindowManager HideDesktop -int 0
# 隐藏小部件
defaults write com.apple.WindowManager StageManagerHideWidgets -int 0
defaults write com.apple.WindowManager StandardHideWidgets -int 0

# ---------------------------------------------------------------------------------------------------------------------
# Screen Capture 设置
# ---------------------------------------------------------------------------------------------------------------------
# 设置屏幕截图存储位置和类型
defaults write com.apple.screencapture location -string "~/Documents/Screenshots"
defaults write com.apple.screencapture type -string "png"
killall SystemUIServer

# ---------------------------------------------------------------------------------------------------------------------
# Software Update 设置
# ---------------------------------------------------------------------------------------------------------------------
# 禁用自动检查更新
defaults write com.apple.SoftwareUpdate AutomaticCheckEnabled -bool false
# 每日检查更新
defaults write com.apple.SoftwareUpdate ScheduleFrequency -int 1
# 禁止在后台下载更新
defaults write com.apple.SoftwareUpdate AutomaticDownload -int 0
# 安装系统数据和安全更新
defaults write com.apple.SoftwareUpdate CriticalUpdateInstall -int 1

# ---------------------------------------------------------------------------------------------------------------------
# Dock settings
# ---------------------------------------------------------------------------------------------------------------------
# position
defaults write com.apple.dock "orientation" -string "left"
# 自动隐藏 Dock
defaults write com.apple.dock autohide -bool true
# 显示应用程序的进程指示器（如闪烁的应用程序图标）
defaults write com.apple.dock show-process-indicators -bool true
# 不显示最近使用的项目
defaults write com.apple.dock show-recents -bool false
# 不仅显示静态应用程序图标（动态图标如正在运行的应用会显示）
defaults write com.apple.dock static-only -bool false
# 设置右下角为 Hot Corner (1 = Bottom Right)
defaults write com.apple.dock wvous-br-corner -int 1
# Minimize windows into their application’s icon
defaults write com.apple.dock minimize-to-application -bool false
# Set the icon size of Dock items in pixels
defaults write com.apple.dock "tilesize" -int 43
# Clear Dock of all default icons and set my own
defaults write com.apple.dock persistent-others -array
defaults write com.apple.dock persistent-apps -array\
 '<dict><key>tile-data</key><dict><key>file-data</key><dict><key>_CFURLString</key><string>/System/Applications/Apps.app</string><key>_CFURLStringType</key><integer>0</integer></dict></dict></dict>'\
 '<dict><key>tile-data</key><dict><key>file-data</key><dict><key>_CFURLString</key><string>/System/Applications/System Settings.app</string><key>_CFURLStringType</key><integer>0</integer></dict></dict></dict>'\
 '<dict><key>tile-data</key><dict><key>file-data</key><dict><key>_CFURLString</key><string>/Applications/Google Chrome.app</string><key>_CFURLStringType</key><integer>0</integer></dict></dict></dict>'\
 '<dict><key>tile-data</key><dict><key>file-data</key><dict><key>_CFURLString</key><string>/Applications/Visual Studio Code.app</string><key>_CFURLStringType</key><integer>0</integer></dict></dict></dict>'\
 '<dict><key>tile-data</key><dict><key>file-data</key><dict><key>_CFURLString</key><string>/Applications/WezTerm.app</string><key>_CFURLStringType</key><integer>0</integer></dict></dict></dict>'
killall Dock


# ---------------------------------------------------------------------------------------------------------------------
# Finder
# ---------------------------------------------------------------------------------------------------------------------
# 显示所有文件扩展名
defaults write com.apple.finder AppleShowAllExtensions -bool true
# 显示 Finder 的路径栏
defaults write com.apple.finder ShowPathbar -bool true
# 禁止更改文件扩展名时显示警告
defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false
# Show hidden files in the Finder
defaults write com.apple.Finder "AppleShowAllFiles" -bool "true"
# Allowing text selection in Quick Look/Preview in Finder by default
defaults write com.apple.finder QLEnableTextSelection -bool true
# When performing a search, search the current folder by default
defaults write com.apple.finder FXDefaultSearchScope -string "SCcf"
# Use list view in all Finder windows by default
defaults write com.apple.finder FXPreferredViewStyle -string "Nlsv"
defaults write com.apple.finder SearchRecentsSavedViewStyle -string "Nlsv"
## Remove CMD+Space shortcut for Spotlight (So Alfred can use it)
#/usr/libexec/PlistBuddy ~/Library/Preferences/com.apple.symbolichotkeys.plist -c "Delete :AppleSymbolicHotKeys:64"
#/usr/libexec/PlistBuddy ~/Library/Preferences/com.apple.symbolichotkeys.plist -c "Add :AppleSymbolicHotKeys:64:enabled bool false"
killall Finder

# ---------------------------------------------------------------------------------------------------------------------
# Trackpad
# ---------------------------------------------------------------------------------------------------------------------
# 禁用 Trackpad 点击
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool false
# 禁用三指拖动
defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerDrag -bool false

# ---------------------------------------------------------------------------------------------------------------------
# Maccy
# ---------------------------------------------------------------------------------------------------------------------
defaults write org.p0deje.Maccy KeyboardShortcuts_delete -int 0
defaults write org.p0deje.Maccy KeyboardShortcuts_pin -int 0
defaults write org.p0deje.Maccy KeyboardShortcuts_popup -string '{"carbonKeyCode":9,"carbonModifiers":768}'
defaults write org.p0deje.Maccy "NSWindow Frame com.sindresorhus.Settings.FrameAutosaveName" -string "465 574 510 232 0 0 1440 900"
defaults write org.p0deje.Maccy pasteByDefault -int 1
defaults write org.p0deje.Maccy removeFormattingByDefault -int 1
defaults write org.p0deje.Maccy historySize -int 200
killall Maccy >/dev/null 2>&1

# ---------------------------------------------------------------------------------------------------------------------
# vscode
# ---------------------------------------------------------------------------------------------------------------------
# 关闭vscode中 长按出带注音的字母 功能
defaults write com.microsoft.VSCode ApplePressAndHoldEnabled -bool false 

# ---------------------------------------------------------------------------------------------------------------------
# 其他杂项设置
# ---------------------------------------------------------------------------------------------------------------------
# 禁止个性化广告
defaults write com.apple.AdLib allowApplePersonalizedAdvertising -bool false
# 禁止设备连接时自动打开应用
defaults write com.apple.ImageCapture disableHotPlug -bool true && killall Photos
# 打印完成后自动退出打印机应用
defaults write com.apple.print.PrintingPrefs "Quit When Finished" -bool true
# 不提供新的磁盘用于备份
defaults write com.apple.TimeMachine DoNotOfferNewDisksForBackup -bool true
# 启用应用程序自动更新
defaults write com.apple.commerce AutoUpdate -bool true



# activateSettings -u will reload the settings from the database and
# apply them to the current session, so we do not need to logout and
# login again to make the changes take effect.
/System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u

{{ end }}