#!/bin/sh
# Load the bwssh-agent LaunchAgent (macOS only) so the Bitwarden-backed SSH agent
# starts at login and auto-recovers from crashes. The plist wraps bwssh-agentd in
# a login shell (mise activation) and is deployed to
# ~/Library/LaunchAgents/io.github.reidond.bwssh-agent.plist.
#
# Linux runs bwssh via systemd (~/.config/systemd/user/bwssh-agent.service), which
# this script intentionally does NOT touch — per the user's instruction, bwssh
# autostart here is macOS-only.
#
# Idempotent. Re-runs whenever bwssh.agent.version changes — bump it in
# .chezmoidata.yaml to force a reload after editing the plist.
# config-version={{ .bwssh.agent.version }}
set -eu

{{ if eq .chezmoi.os "darwin" }}
# ---------------------------------------------------------------------------------------------------------------------
# macOS — load the bwssh-agent LaunchAgent into the per-user GUI domain.
# ---------------------------------------------------------------------------------------------------------------------
LABEL="io.github.reidond.bwssh-agent"
DOMAIN="gui/$(id -u)"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"

if [ ! -f "$PLIST" ]; then
  echo "[bwssh-agent] plist not found at $PLIST — re-run 'chezmoi apply'." >&2
  exit 0
fi

# If the agent is already loaded, unload it FIRST and wait for launchd to
# actually deregister it before re-loading. `bootout` returns before teardown
# completes — and bwssh-agentd (a Python daemon) can take a moment to exit on
# SIGTERM — so bootstrapping immediately races the deregistration and fails
# with "Bootstrap failed: 5: Input/output error". Polling until `print` reports
# the service gone closes that window.
if launchctl print "$DOMAIN/$LABEL" >/dev/null 2>&1; then
  launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || true
  i=0
  while launchctl print "$DOMAIN/$LABEL" >/dev/null 2>&1 && [ "$i" -lt 20 ]; do
    i=$((i + 1))
    sleep 0.2
  done
fi

launchctl bootstrap "$DOMAIN" "$PLIST"
# Re-enable in case it was disabled via `launchctl disable`.
launchctl enable "$DOMAIN/$LABEL"

echo "[bwssh-agent] launchd agent loaded: $LABEL"
{{ end }}
