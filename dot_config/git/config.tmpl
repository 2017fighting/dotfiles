[oh-my-zsh]
	git-commit-alias = ad817678640095bbf286f66c4980aed5d3213e9a

# ─────────────────────────────────────────────────────────────
# URL Rewriting - Use SSH instead of HTTPS for git operations
# This allows using SSH keys for authentication
# ─────────────────────────────────────────────────────────────
[url "ssh://git@github.com/"]
    insteadOf = https://github.com/

[url "ssh://git@gitlab.com/"]
    insteadOf = https://gitlab.com/

[url "ssh://git@bitbucket.org/"]
    insteadOf = https://bitbucket.org/

# [credential "https://github.com"]
#         helper =
#         helper = !/opt/homebrew/bin/gh auth git-credential
# 
# [credential "https://gist.github.com"]
#         helper =
#         helper = !/opt/homebrew/bin/gh auth git-credential
[credential]
	helper = store

[includeIf "gitdir:{{ .chezmoi.homeDir }}/work/"]
    path = {{ .chezmoi.homeDir }}/.config/git/config-work

