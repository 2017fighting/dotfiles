merge:
  command: nvim
  args:
    - -d
    - {{ printf "%q" "{{ .Destination }}" }}
    - {{ printf "%q" "{{ .Source }}" }}
    - {{ printf "%q" "{{ .Target }}" }}

# Show human-friendly diffs for binary files
textconv:
  - pattern: "**/*.plist"  # MacOS file
    command: "plutil"
    args:
      - "-convert"
      - "xml1"
      - "-o"
      - "-"
      - "-"

